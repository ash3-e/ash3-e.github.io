}

body.theme-balanced .toc-group-toggle,
body.theme-balanced .toc-group-title,
body.theme-balanced .toc-caret,
body.theme-balanced .toc-sublist a,
body.theme-half .toc-group-toggle,
body.theme-half .toc-group-title,
body.theme-half .toc-caret,
body.theme-half .toc-sublist a {
