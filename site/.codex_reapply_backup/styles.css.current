}

body.theme-balanced .markdown-body,
body.theme-balanced .markdown-body p,
body.theme-balanced .markdown-body li,
body.theme-balanced .markdown-body td,
body.theme-balanced .markdown-body th,
body.theme-half .markdown-body,
body.theme-half .markdown-body p,
body.theme-half .markdown-body li,
body.theme-half .markdown-body td,
body.theme-half .markdown-body th {
  color: #edf3ff !important;
}

body.dark .title-card h1 {
  color: #ffffff;
  text-shadow:
    0 0 20px rgba(98, 0, 255, 0.45),
    0 1px 2px rgba(0, 0, 0, 0.95);
}

body.dark .title-card p {
  color: #d7ddf2;
}

body.dark .btn.secondary {
  background: #f0f4ff;
  border-color: #8f9bbc;
  color: #2a3765;
  animation:
    intro-pulse-dark 1.8s ease-in-out infinite,
    intro-breathe 2.2s ease-in-out infinite;
}

body.theme-balanced .title-card,
body.theme-half .title-card {
  background: #1a2434;
  border-color: #495b7a;
}

body.theme-balanced .title-card h1,
body.theme-half .title-card h1 {
  color: #f0f4ff;
}

body.theme-balanced .title-card p,
body.theme-half .title-card p {
  color: #dce6fb;
}

body.theme-balanced .btn.secondary,
body.theme-half .btn.secondary {
  background: #edf2ff;
  color: #283867;
  border-color: #8ea2d3;
  animation:
    intro-pulse-dark 1.8s ease-in-out infinite,
    intro-breathe 2.2s ease-in-out infinite;
}

@keyframes intro-pulse-dark {
  0% {
    box-shadow: 0 0 0 0 rgba(165, 187, 255, 0.58);
  }

  70% {
    box-shadow: 0 0 0 11px rgba(165, 187, 255, 0);
  }

  100% {
    box-shadow: 0 0 0 0 rgba(165, 187, 255, 0);
  }
}

body.theme-balanced::before,
body.theme-half::before {
  background: linear-gradient(180deg, #3a00b8 0%, #b782ff 100%);
}

body.theme-balanced::after,
body.theme-half::after {
  content: none;
}

body.theme-balanced[data-page-type="home"]::after,
body.theme-half[data-page-type="home"]::after {
  background: linear-gradient(0deg,
      rgba(11, 16, 24, 0.62) 0%,
      rgba(20, 28, 42, 0.48) 48%,
      rgba(14, 20, 31, 0.68) 100%);
}

body.theme-balanced .toc-group,
body.theme-balanced .toc-sublist a,
body.theme-balanced .markdown-body pre,
body.theme-balanced .markdown-body code,
body.theme-balanced .markdown-body table,
body.theme-balanced .markdown-body tr,
body.theme-balanced .markdown-body td,
body.theme-balanced .markdown-body th,
body.theme-balanced .markdown-body blockquote,
body.theme-half .toc-group,
body.theme-half .toc-sublist a,
body.theme-half .markdown-body pre,
body.theme-half .markdown-body code,
body.theme-half .markdown-body table,
body.theme-half .markdown-body tr,
body.theme-half .markdown-body td,
body.theme-half .markdown-body th,
body.theme-half .markdown-body blockquote {
  background: #111722 !important;
  border-color: #3b4961 !important;
}

body.theme-balanced .reader-body .markdown-body,
body.theme-balanced .markdown-body,
body.theme-half .reader-body .markdown-body,
body.theme-half .markdown-body {
  background: #141c29 !important;
}

body.theme-balanced,
body.theme-balanced *,
body.theme-half,
body.theme-half * {
  scrollbar-color: #4d5a74 #131a26;
}

body.theme-balanced ::-webkit-scrollbar-track,
body.theme-half ::-webkit-scrollbar-track {
  background: #131a26;
}

body.theme-balanced ::-webkit-scrollbar-thumb,
body.theme-half ::-webkit-scrollbar-thumb {
  background: #4d5a74;
  border: 2px solid #131a26;
}
