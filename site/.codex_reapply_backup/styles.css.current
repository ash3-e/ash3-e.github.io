}

body.theme-balanced .toc-sublist a.active,
body.theme-half .toc-sublist a.active {
  background: #233047 !important;
  color: #f4f8ff !important;
}

body.theme-balanced .toc-group-toggle.active,
body.theme-half .toc-group-toggle.active {
  background: #233047 !important;
  color: #f4f8ff !important;
}

body.theme-balanced .dock-btn-close,
body.theme-half .dock-btn-close {
  border-color: #141c29 !important;
}

body.dark .toc-group,
body.dark .toc-sublist a,
body.dark .markdown-body pre,
body.dark .markdown-body code,
body.dark .markdown-body table,
body.dark .markdown-body tr,
body.dark .markdown-body td,
body.dark .markdown-body th,
body.dark .markdown-body blockquote {
  background: #000 !important;
  border-color: #303544 !important;
}

body.dark .markdown-body pre,
body.theme-balanced .markdown-body pre,
body.theme-half .markdown-body pre {
  border: 1px solid rgba(170, 178, 196, 0.3) !important;
}

body.dark .markdown-body pre code,
body.theme-balanced .markdown-body pre code,
body.theme-half .markdown-body pre code {
  border: 0 !important;
}

body.dark .find-count-inline,
body.theme-balanced .find-count-inline,
body.theme-half .find-count-inline {
  color: rgba(188, 196, 210, 0.92) !important;
}

body.dark .reader-body .markdown-body,
body.dark .markdown-body {
  background: #000 !important;
  color: #f2f4ff !important;
}

body.dark .markdown-body a {
  color: #9fbcff;
}

body.dark .hljs,
body.dark .hljs * {
  text-shadow: none !important;
}

body.dark .hljs-number,
body.dark .hljs-literal,
body.dark .hljs-string,
body.dark .hljs-symbol,
body.dark .hljs-variable {
  filter: saturate(1.1);
}

body.theme-balanced .doc-card .meta,
body.theme-balanced .doc-card .desc,
body.theme-balanced .search-meta,
body.theme-balanced .find-count,
body.theme-balanced .reader-meta,
body.theme-balanced .doc-sub,
body.theme-balanced .toggle,
body.theme-balanced .footer-sep,
body.theme-balanced .footer-right,
body.theme-balanced p,
body.theme-half .doc-card .meta,
body.theme-half .doc-card .desc,
body.theme-half .search-meta,
body.theme-half .find-count,
body.theme-half .reader-meta,
